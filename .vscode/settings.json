{
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always",
    "source.organizeImports": "never"
  },
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue"
  ],
  "eslint.workingDirectories": [
    {
      "directory": "apps/web-user",
      "changeProcessCWD": true
    },
    {
      "directory": "apps/web-admin",
      "changeProcessCWD": true
    }
  ]
}
