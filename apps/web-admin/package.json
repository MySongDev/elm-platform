{
  "name": "elm-web-admin",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "vue-tsc --noEmit && vite build",
    "type-check": "vue-tsc --noEmit",
    "test:unit": "vitest run",
    "preview": "vite preview",
    "lint": "eslint . --fix --cache",
    "lint:style": "pnpm --dir ../.. exec stylelint \"apps/web-admin/src/**/*.{vue,scss,css}\" --fix --config stylelint.config.mjs"
  },
  "dependencies": {
    "@elm-platform/contracts": "workspace:*",
    "@vueuse/core": "catalog:",
    "axios": "catalog:",
    "echarts": "catalog:",
    "element-plus": "catalog:",
    "mitt": "catalog:",
    "nprogress": "catalog:",
    "pinia": "catalog:",
    "pinia-plugin-persistedstate": "catalog:",
    "vue": "catalog:",
    "vue-echarts": "catalog:",
    "vue-i18n": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "@elm-platform/tsconfig": "workspace:*",
    "@elm-platform/vite-config": "workspace:*",
    "@iconify-prerendered/vue-ep": "catalog:",
    "@types/nprogress": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "fast-glob": "catalog:",
    "sass-embedded": "catalog:",
    "unplugin-auto-import": "catalog:",
    "unplugin-vue-components": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue-tsc": "catalog:"
  }
}
