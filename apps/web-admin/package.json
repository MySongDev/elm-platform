{
  "name": "elm-web-admin",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "vue-tsc --noEmit && vite build",
    "type-check": "vue-tsc --noEmit",
    "test:unit": "vitest run",
    "preview": "vite preview",
    "lint": "eslint . --fix --cache",
    "lint:style": "pnpm --dir ../.. exec stylelint \"apps/web-admin/src/**/*.{vue,scss,css}\" --fix --config stylelint.config.mjs"
  },
  "dependencies": {
    "@elm-platform/contracts": "workspace:*",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.13.3",
    "echarts": "^6.1.0",
    "element-plus": "^2.9.8",
    "mitt": "^3.0.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.26",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^11.1.2",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@elm-platform/tsconfig": "workspace:*",
    "@elm-platform/vite-config": "workspace:*",
    "@iconify-prerendered/vue-ep": "^0.28.1754542231",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "fast-glob": "^3.3.3",
    "sass-embedded": "^1.97.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.9"
  }
}
