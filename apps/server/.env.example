# 应用配置
APP_PORT=3000
APP_PREFIX=api

# 数据库配置
DATABASE_URL="postgresql://postgres:password@localhost:5432/database_name?schema=public"

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 认证配置
CUSTOMER_LOGIN_AUTO_REGISTER=true

# 短信配置
# mock 仅用于开发；生产环境必须接入真实短信服务商
SMS_PROVIDER=mock
SMS_MOCK_CODE=123456
SMS_CODE_TTL_SECONDS=300
SMS_COOLDOWN_SECONDS=60
SMS_DAILY_LIMIT=10
