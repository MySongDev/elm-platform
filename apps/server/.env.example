# 应用配置
APP_PORT=3000
APP_PREFIX=api

# 数据库配置
# 本地 Docker Compose 默认连接：postgres/postgres@localhost:5432/elm_dev
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/elm_dev?schema=public"

# Redis 配置
# 本地 Docker Compose 默认暴露 localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 认证配置
CUSTOMER_LOGIN_AUTO_REGISTER=true

# 短信配置
# mock 仅用于开发；生产环境必须接入真实短信服务商
SMS_PROVIDER=mock
SMS_MOCK_CODE=123456
SMS_CODE_TTL_SECONDS=300
SMS_COOLDOWN_SECONDS=60
SMS_DAILY_LIMIT=10

# 支付宝配置
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_SELLER_ID=
ALIPAY_NOTIFY_URL=https://your-public-domain.example.com/api/payments/alipay/notify
ALIPAY_RETURN_URL=http://127.0.0.1:5173/#/payment/result
