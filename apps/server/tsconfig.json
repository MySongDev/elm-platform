{
  "extends": "@elm-platform/tsconfig/node-nestjs.json",
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "@common/*": ["src/common/*"],
      "@config/*": ["src/config/*"],
      "@prisma/*": ["src/prisma/*"],
      "@redis/*": ["src/redis/*"]
