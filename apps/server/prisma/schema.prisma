// Prisma Schema 配置
// 文档: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 示例模型 - 用户表
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  email     String?  @unique
  phone     String?  @unique
  avatar    String?
  status    Int      @default(1) // 1: 启用 0: 禁用
  role      String   @default("user") // "admin" | "user"
  permissions String[] @default([]) // 按钮级权限码，如 ["user:add", "user:delete"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loginLogs LoginLog[]

  @@map("users")
}

model CustomerUser {
  id          Int       @id @default(autoincrement())
  phone       String    @unique
  password    String?
  nickname    String?
  avatar      String?
  status      Int       @default(1)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("customer_users")
}

model LoginLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  ip        String?
  address   String?
  browser   String?
  os        String?
  status    Int      @default(1) // 1: 成功 0: 失败
  message   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("login_logs")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  status      Int      @default(1)
  remark      String?
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model Menu {
  id         Int      @id @default(autoincrement())
  parentId   Int?
  title      String
  path       String   @default("")
  name       String?
  icon       String?
  permission String?
  type       String   @default("menu") // catalog | menu | button
  sort       Int      @default(0)
  status     Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  parent   Menu?  @relation("MenuTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Menu[] @relation("MenuTree")

  @@map("menus")
}

model Dept {
  id        Int      @id @default(autoincrement())
  parentId  Int?
  name      String
  leader    String?
  phone     String?
  email     String?
  sort      Int      @default(0)
  status    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Dept?  @relation("DeptTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Dept[] @relation("DeptTree")

  @@map("depts")
}

model OperationLog {
  id        Int      @id @default(autoincrement())
  username  String
  module    String
  action    String
  method    String
  path      String
  ip        String?
  status    Int      @default(1)
  duration  Int      @default(0)
  createdAt DateTime @default(now())

  @@map("operation_logs")
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  level     String   @default("info")
  source    String
  message   String
  detail    String?
  createdAt DateTime @default(now())

  @@map("system_logs")
}
