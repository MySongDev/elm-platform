{
  "name": "@elm-platform/contracts",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Shared domain constants and types for elm-platform monorepo",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./order": {
      "types": "./dist/order/index.d.ts",
      "import": "./dist/order/index.mjs",
      "require": "./dist/order/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "order": ["./dist/order/index.d.ts"]
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@elm-platform/tsconfig": "workspace:*",
    "tsup": "catalog:"
  }
}
